---
import Layout from "@/layouts/Layout.astro";
import NavHeader from "@/components/NavHeader.astro";
---

<Layout
  title="Check Any HF Model - CanIRun.ai"
  description="Paste any Hugging Face model URL, detect your hardware, and get an instant local run verdict."
>
  <NavHeader />
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <section class="rounded-2xl border border-edge bg-surface-card/70 p-6 shadow-[0_12px_60px_rgba(0,0,0,0.2)] sm:p-8">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent/80">HF URL check</p>
        <h1 class="mt-3 font-pixel text-3xl text-primary sm:text-4xl">Paste any Hugging Face model URL</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-secondary sm:text-base">
          We detect your hardware in the browser, fetch model metadata from Hugging Face, estimate VRAM and RAM,
          then tell you if local run looks great, tight, or too heavy.
        </p>
      </div>

      <form id="hf-check-form" class="mt-8">
        <label for="hf-url" class="mb-2 block font-mono text-xs uppercase tracking-[0.2em] text-muted">Model URL</label>
        <div class="flex flex-col gap-3 sm:flex-row">
          <input
            id="hf-url"
            name="url"
            type="url"
            required
            placeholder="https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct"
            class="min-w-0 flex-1 rounded-xl border border-edge bg-surface px-4 py-3 font-mono text-sm text-primary outline-none transition-colors focus:border-accent/50"
          />
          <button
            id="hf-submit"
            type="submit"
            class="inline-flex items-center justify-center rounded-xl border border-accent/40 bg-accent/10 px-5 py-3 font-mono text-sm text-accent transition-colors hover:bg-accent/15"
          >
            Check model
          </button>
        </div>
      </form>

      <div id="hf-hardware" class="mt-6 rounded-xl border border-edge/70 bg-surface/60 p-4 font-mono text-sm text-secondary">
        Detecting hardware...
      </div>
    </section>

    <section id="hf-results" class="mt-8 hidden">
      <div class="grid gap-6 lg:grid-cols-[1.35fr,0.95fr]">
        <div class="rounded-2xl border border-edge bg-surface-card/70 p-6">
          <div id="hf-summary"></div>
        </div>
        <div class="rounded-2xl border border-edge bg-surface-card/70 p-6">
          <h2 class="font-pixel text-lg text-primary">Profiles</h2>
          <div id="hf-profiles" class="mt-4 space-y-3"></div>
        </div>
      </div>
    </section>

    <div id="hf-error" class="mt-6 hidden rounded-xl border border-red-500/30 bg-red-500/10 p-4 font-mono text-sm text-red-300"></div>
  </main>
</Layout>

<script>
  import {
    detectHardware,
    evaluateModelComplete,
    getDisplayName,
    type HardwareInfo,
    GRADES,
  } from "@/lib/hardware"

  type Profile = {
    label: string
    tensorType: string
    source: string
    estimatedVRAMGB: number
    estimatedRAMGB: number
    diskGB: number | null
  }

  type ModelPayload = {
    model: {
      repoId: string
      canonicalUrl: string
      displayName: string
      modelKind: "full" | "adapter"
      runtimeRepoId: string | null
      runtimeDisplayName: string | null
      architecture: string
      rawArchitecture: string | null
      paramsBillions: number | null
      tensorType: string
      contextLength: number | null
      license: string | null
      adapterDiskGB: number | null
      confidence: string
      notes: string[]
      profiles: Profile[]
    }
    primaryProfile: Profile | null
  }

  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("hf-check-form") as HTMLFormElement | null
    const input = document.getElementById("hf-url") as HTMLInputElement | null
    const hardwareEl = document.getElementById("hf-hardware")
    const resultsEl = document.getElementById("hf-results")
    const summaryEl = document.getElementById("hf-summary")
    const profilesEl = document.getElementById("hf-profiles")
    const errorEl = document.getElementById("hf-error")

    if (!form || !input || !hardwareEl || !resultsEl || !summaryEl || !profilesEl || !errorEl) return

    let hw: HardwareInfo | null = null

    function setError(message: string) {
      errorEl.textContent = message
      errorEl.classList.remove("hidden")
    }

    function clearError() {
      errorEl.textContent = ""
      errorEl.classList.add("hidden")
    }

    function renderHardware(current: HardwareInfo) {
      hardwareEl.innerHTML = `
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
          <span><span class="text-muted">Device:</span> <span class="text-primary">${getDisplayName(current)}</span></span>
          <span><span class="text-muted">VRAM:</span> <span class="text-primary">${current.estimatedVRAM ?? current.totalUsableRAM ?? "?"} GB</span></span>
          <span><span class="text-muted">RAM:</span> <span class="text-primary">${current.systemRAM ?? current.totalUsableRAM ?? "?"} GB</span></span>
          <span><span class="text-muted">BW:</span> <span class="text-primary">${current.memoryBandwidth ?? "?"} GB/s</span></span>
        </div>
      `
    }

    function verdictHtml(profile: Profile, paramsBillions: number | null) {
      if (!hw || !paramsBillions) {
        return `<span class="text-muted">Need exact parameter count for verdict.</span>`
      }

      const result = evaluateModelComplete(profile.estimatedVRAMGB, hw, paramsBillions)
      const gradeInfo = GRADES[result.grade]
      return `
        <div class="mt-4 rounded-xl border border-edge/70 bg-surface/60 p-4">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Primary verdict</p>
              <p class="mt-2 font-pixel text-2xl" style="color:${gradeInfo.color}">${gradeInfo.label}</p>
            </div>
            <div class="text-right font-mono text-xs text-secondary">
              <p>grade ${result.grade}</p>
              <p>${result.toksPerSec ? `~${result.toksPerSec} tok/s` : "speed unknown"}</p>
              <p>${result.memPct !== null ? `${result.memPct}% memory use` : "memory headroom unknown"}</p>
            </div>
          </div>
        </div>
      `
    }

    function renderResult(payload: ModelPayload) {
      const { model, primaryProfile } = payload
      const paramsText = model.paramsBillions ? `${model.paramsBillions}B params` : "params unknown"
      const contextText = model.contextLength ? `${Math.round(model.contextLength / 1024)}K context` : "context unknown"
      const primary = primaryProfile || model.profiles[0] || null
      const runtimeText =
        model.modelKind === "adapter" && model.runtimeRepoId
          ? `<p class="text-sm text-secondary">Runtime base: ${model.runtimeRepoId}</p>`
          : ""
      const adapterText =
        model.modelKind === "adapter"
          ? `<p class="text-sm text-secondary">${model.adapterDiskGB !== null ? `Adapter files ~${model.adapterDiskGB} GB disk` : "Adapter repo detected"}</p>`
          : ""

      summaryEl.innerHTML = `
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent/80">${model.confidence} confidence</p>
            <h2 class="mt-2 font-pixel text-2xl text-primary">${model.displayName}</h2>
            <p class="mt-2 font-mono text-sm text-secondary">${model.repoId}</p>
            ${runtimeText}
          </div>
          <a
            href="${model.canonicalUrl}"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-full border border-yellow-400/30 bg-yellow-400/10 px-3 py-1.5 font-mono text-xs text-yellow-300"
          >
            Open on Hugging Face
          </a>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl border border-edge/70 bg-surface/60 p-3">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Metadata</p>
            <p class="mt-2 text-sm text-primary">${paramsText}</p>
            <p class="text-sm text-secondary">${model.rawArchitecture || model.architecture}</p>
            <p class="text-sm text-secondary">${model.tensorType.toUpperCase()} / ${contextText}</p>
            ${adapterText}
          </div>
          <div class="rounded-xl border border-edge/70 bg-surface/60 p-3">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Estimate</p>
            ${
              primary
                ? `<p class="mt-2 text-sm text-primary">${primary.label}</p>
                   <p class="text-sm text-secondary">~${primary.estimatedVRAMGB} GB VRAM</p>
                   <p class="text-sm text-secondary">~${primary.estimatedRAMGB} GB RAM</p>
                   ${model.modelKind === "adapter" && model.runtimeDisplayName ? `<p class="text-sm text-secondary">Estimate uses base model ${model.runtimeDisplayName}</p>` : ""}`
                : `<p class="mt-2 text-sm text-secondary">No usable estimate found.</p>`
            }
          </div>
        </div>

        ${primary ? verdictHtml(primary, model.paramsBillions) : ""}

        ${
          model.notes.length
            ? `<div class="mt-4 rounded-xl border border-edge/70 bg-surface/40 p-4">
                <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Notes</p>
                <ul class="mt-2 space-y-2 text-sm text-secondary">
                  ${model.notes.map((note) => `<li>${note}</li>`).join("")}
                </ul>
              </div>`
            : ""
        }
      `

      profilesEl.innerHTML = model.profiles.length
        ? model.profiles
            .map((profile) => {
              let verdict = "Need params"
              let verdictColor = "var(--color-muted)"
              if (hw && model.paramsBillions) {
                const result = evaluateModelComplete(profile.estimatedVRAMGB, hw, model.paramsBillions)
                verdict = GRADES[result.grade].label
                verdictColor = GRADES[result.grade].color
              }
              return `
                <article class="rounded-xl border border-edge/70 bg-surface/55 p-4">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <h3 class="font-mono text-sm text-primary">${profile.label}</h3>
                      <p class="mt-1 text-xs uppercase tracking-[0.16em] text-muted">${profile.tensorType.toUpperCase()} / ${profile.source}</p>
                    </div>
                    <span class="font-mono text-xs uppercase tracking-[0.16em]" style="color:${verdictColor}">${verdict}</span>
                  </div>
                  <div class="mt-3 grid grid-cols-3 gap-2 font-mono text-xs text-secondary">
                    <span>${profile.estimatedVRAMGB} GB VRAM</span>
                    <span>${profile.estimatedRAMGB} GB RAM</span>
                    <span>${profile.diskGB !== null ? `${profile.diskGB} GB disk` : "disk ?"}</span>
                  </div>
                </article>
              `
            })
            .join("")
        : `<p class="text-sm text-secondary">No estimate profiles found.</p>`

      resultsEl.classList.remove("hidden")
    }

    async function init() {
      try {
        hw = await detectHardware()
        renderHardware(hw)
      } catch {
        hardwareEl.textContent = "Hardware detection failed. You can still inspect metadata."
      }
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault()
      clearError()

      const url = input.value.trim()
      if (!url) {
        setError("Paste a Hugging Face model URL first.")
        return
      }

      const button = document.getElementById("hf-submit") as HTMLButtonElement | null
      if (button) {
        button.disabled = true
        button.textContent = "Checking..."
      }

      try {
        const response = await fetch(`/api/hf/model?url=${encodeURIComponent(url)}`)
        const payload = await response.json()
        if (!response.ok) {
          setError(payload.error === "invalid_huggingface_url" ? "URL does not look like a Hugging Face model repo." : "Could not fetch metadata from Hugging Face.")
          return
        }
        renderResult(payload as ModelPayload)
      } catch {
        setError("Request failed. Try again in a moment.")
      } finally {
        if (button) {
          button.disabled = false
          button.textContent = "Check model"
        }
      }
    })

    init()
  })
</script>
