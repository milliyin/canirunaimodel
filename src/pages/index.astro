---
import Layout from "@/layouts/Layout.astro";
import NavHeader from "@/components/NavHeader.astro";
import ModelListContent from "@/components/ModelListContent.astro";

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://canirunaimodel.vercel.app";
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "canirunaimodel",
      "url": siteUrl,
      "description": "Paste a Hugging Face model URL, detect your hardware, and estimate whether the model will run locally.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web Browser",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "creator": { "@type": "Person", "name": "milliyin", "url": "https://milliyin.dev/" }
    })}></script>
  </Fragment>
  <NavHeader />
  <ModelListContent>
    <header slot="header" class="mb-10 text-center">
      <h1 class="font-pixel text-3xl tracking-tight text-accent sm:text-4xl">
        Can I run this Hugging Face model?
      </h1>
      <p class="mt-2 text-base text-muted">
        Detect your hardware, inspect model metadata, and estimate whether a Hugging Face repo will run locally.
      </p>
      <p class="mt-3 font-mono text-xs uppercase tracking-[0.18em] text-primary/50">
        Models today. Datasets and Spaces next.
      </p>
    </header>
  </ModelListContent>
</Layout>
