{
  "name": "runai",
  "version": "0.1.0",
  "description": "Local AI runtime with hardware-aware recommendations and OpenAI-compatible API",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "bin": {
    "runai": "./bin/runai"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build ./src/cli.ts --target bun --outfile ./dist/cli.js",
    "test": "vitest run",
    "recommend": "bun src/cli.ts recommend",
    "browse": "bun src/cli.ts browse",
    "serve": "bun src/cli.ts serve",
    "api": "bun src/cli.ts api"
  },
  "devDependencies": {
    "@types/bun": "1.3.14"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "1.4.0",
    "fast-string-width": "3.0.2",
    "node-llama-cpp": "3.18.1"
  }
}
